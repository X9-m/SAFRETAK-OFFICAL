    "test:render": "node tests/render-smoke.mjs",
    "check": "npm run lint && npm test && npm run test:render && npm run build",
    "prepare:media": "node scripts/prepare-media.mjs"
  },
  "dependencies": {
    "lucide-react": "0.546.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "typescript": "5.8.3",
    "vite": "6.4.3"
  }
}
