rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- Reusable Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Check if the current user is a registered admin
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'fullName', 'phone', 'role']) &&
             data.keys().size() >= 4 && data.keys().size() <= 7 &&
             data.id is string &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.role in ['traveler', 'office', 'admin'];
    }
    
    function isValidTravelOffice(data) {
      return data.keys().hasAll(['id', 'name', 'subscriptionPlan', 'balance', 'complaintsCount', 'isApproved']) &&
             data.name is string && data.name.size() <= 100 &&
             data.subscriptionPlan in ['Free', 'Basic', 'Premium'] &&
             data.balance is number &&
             data.complaintsCount is number &&
             data.isApproved is bool;
    }
    
    function isValidService(data) {
      return data.keys().hasAll(['id', 'officeId', 'officeName', 'type', 'title', 'price']) &&
             data.title is string && data.title.size() <= 150 &&
             data.price is number && data.price >= 0 &&
             data.type in ['trip', 'hotel', 'car', 'flight', 'bus_train', 'hajj_umrah', 'insurance', 'visa', 'consultation'];
    }
    
    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'serviceType', 'serviceId', 'serviceName', 'officeId', 'travelerId', 'travelerName', 'travelerPhone', 'totalPrice', 'paymentMethod', 'paymentStatus', 'status', 'createdAt']) &&
             data.travelerId is string &&
             data.travelerName is string && data.travelerName.size() <= 100 &&
             data.travelerPhone is string && data.travelerPhone.size() <= 20 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.paymentMethod in ['CliQ', 'eFAWATEERcom', 'Visa', 'MasterCard', 'Cash at Office'] &&
             data.paymentStatus in ['unpaid', 'paid'] &&
             data.status in ['Pending', 'Confirmed', 'Completed', 'Cancelled'];
    }
    
    function isValidReview(data) {
      return data.keys().hasAll(['id', 'serviceId', 'travelerName', 'rating', 'comment', 'date']) &&
             data.travelerName is string && data.travelerName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 500;
    }
    
    function isValidComplaint(data) {
      return data.keys().hasAll(['id', 'travelerName', 'travelerPhone', 'officeName', 'subject', 'details', 'status', 'createdAt']) &&
             data.travelerName is string && data.travelerName.size() <= 100 &&
             data.travelerPhone is string && data.travelerPhone.size() <= 20 &&
             data.officeName is string && data.officeName.size() <= 100 &&
             data.subject is string && data.subject.size() <= 150 &&
             data.details is string && data.details.size() <= 1000 &&
             data.status in ['Open', 'Resolved'];
    }

    // --- Collection Routes ---

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow delete: if isAdmin();
    }
    
    // --- TRAVEL OFFICES ---
    match /travel_offices/{officeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(officeId) && isValidTravelOffice(incoming());
      allow delete: if isAdmin();
    }
    
    // --- SERVICES ---
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isValidService(incoming());
    }
    
    // --- BOOKINGS ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming());
      allow delete: if isAdmin();
    }
    
    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming());
      allow delete: if isAdmin();
    }
    
    // --- COMPLAINTS ---
    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(complaintId) && isValidComplaint(incoming());
      allow delete: if isAdmin();
    }
  }
}
