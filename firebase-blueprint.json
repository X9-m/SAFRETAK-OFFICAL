{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents travelers, office employees, and admins",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Auth UID" },
        "fullName": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "maxLength": 100 },
        "role": { "type": "string", "enum": ["traveler", "office", "admin"] },
        "avatarUrl": { "type": "string", "maxLength": 256 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "phone", "role"]
    },
    "TravelOffice": {
      "title": "TravelOffice",
      "description": "Represents approved or pending travel agencies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "logo": { "type": "string", "maxLength": 256 },
        "rating": { "type": "number" },
        "location": { "type": "string", "maxLength": 150 },
        "isApproved": { "type": "boolean" },
        "subscriptionPlan": { "type": "string", "enum": ["Free", "Basic", "Premium"] },
        "balance": { "type": "number" },
        "complaintsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "isApproved", "subscriptionPlan", "balance", "complaintsCount"]
    },
    "Service": {
      "title": "Service",
      "description": "Any tourism product (trips, hotels, flights, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "officeId": { "type": "string" },
        "officeName": { "type": "string", "maxLength": 100 },
        "type": { "type": "string", "enum": ["trip", "hotel", "car", "flight", "bus_train", "hajj_umrah", "insurance", "visa", "consultation"] },
        "title": { "type": "string", "maxLength": 150 },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string", "maxLength": 2000 },
        "location": { "type": "string", "maxLength": 150 },
        "terms": { "type": "string", "maxLength": 1000 },
        "cancellationPolicy": { "type": "string", "maxLength": 1000 },
        "subType": { "type": "string", "enum": ["domestic", "international", "Hajj", "Umrah", "SUV", "Sedan", "Luxury", "Economy"] },
        "duration": { "type": "string", "maxLength": 50 },
        "seatsRemaining": { "type": "number" },
        "itinerary": { "type": "array" },
        "included": { "type": "array" }
      },
      "required": ["id", "officeId", "officeName", "type", "title", "price"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A reservation record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceType": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string", "maxLength": 150 },
        "officeId": { "type": "string" },
        "officeName": { "type": "string", "maxLength": 100 },
        "travelerId": { "type": "string" },
        "travelerName": { "type": "string", "maxLength": 100 },
        "travelerPhone": { "type": "string", "maxLength": 20 },
        "bookingDetails": { "type": "object" },
        "totalPrice": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["CliQ", "eFAWATEERcom", "Visa", "MasterCard", "Cash at Office"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Completed", "Cancelled"] },
        "qrCode": { "type": "string" },
        "invoiceUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "chatHistory": { "type": "array" }
      },
      "required": ["id", "serviceType", "serviceId", "serviceName", "officeId", "travelerId", "travelerName", "travelerPhone", "totalPrice", "paymentMethod", "paymentStatus", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Reviews on services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceId": { "type": "string" },
        "travelerName": { "type": "string", "maxLength": 100 },
        "rating": { "type": "number" },
        "comment": { "type": "string", "maxLength": 500 },
        "date": { "type": "string" }
      },
      "required": ["id", "serviceId", "travelerName", "rating", "comment", "date"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Traveler complaint filed against an office",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "travelerName": { "type": "string", "maxLength": 100 },
        "travelerPhone": { "type": "string", "maxLength": 20 },
        "officeName": { "type": "string", "maxLength": 100 },
        "subject": { "type": "string", "maxLength": 150 },
        "details": { "type": "string", "maxLength": 1000 },
        "status": { "type": "string", "enum": ["Open", "Resolved"] },
        "createdAt": { "type": "string" },
        "resolution": { "type": "string", "maxLength": 1000 }
      },
      "required": ["id", "travelerName", "travelerPhone", "officeName", "subject", "details", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users profile collection (RBAC)"
    },
    "/travel_offices/{officeId}": {
      "schema": "TravelOffice",
      "description": "Travel Office profiles"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Services published by offices"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Reservations"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews left by travelers"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Complaints tracked on the platform"
    }
  }
}
